{
    "name": "genia-tech-landing",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "postbuild": "node -e \"if(process.env.VERCEL !== '1') { require('child_process').execSync('react-snap', {stdio: 'inherit'}) }\"",
        "preview": "vite preview"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "framer-motion": "^11.18.2",
        "lucide-react": "^0.344.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-helmet-async": "^2.0.4",
        "react-hook-form": "^7.50.0",
        "react-router-dom": "^7.13.1",
        "tailwind-merge": "^2.6.1"
    },
    "devDependencies": {
        "@types/react": "^18.2.55",
        "@types/react-dom": "^18.2.19",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.17",
        "postcss": "^8.4.35",
        "react-snap": "^1.23.0",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.2.2",
        "vite": "^5.1.0"
    },
    "reactSnap": {
        "source": "dist",
        "destination": "dist",
        "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
        "puppeteerExecutablePath": "C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
        "concurrency": 1,
        "waitFor": 300,
        "include": [
            "/",
            "/contacto",
            "/nosotros",
            "/blog",
            "/casos",
            "/servicios/automatizacion-empresarial",
            "/servicios/software-a-medida",
            "/servicios/inteligencia-artificial-b2b",
            "/industrias/inmobiliarias",
            "/industrias/seguridad-privada",
            "/industrias/agroindustria",
            "/industrias/construccion",
            "/industrias/mineria",
            "/industrias/logistica-transporte",
            "/industrias/clinicas-salud",
            "/industrias/retail-comercio",
            "/industrias/otec-otic",
            "/industrias/servicios-profesionales"
        ]
    }
}
